{
  "$schema": "https://raw.githubusercontent.com/ErikReider/SwayNotificationCenter/main/config.schema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-margin-top": 5,
  "control-center-margin-bottom": 5,
  "control-center-margin-right": 5,
  "control-center-margin-left": 5,
  "notification-icon-size": 48,
  "notification-body-image-height": 160,
  "notification-body-image-width": 240,
  "timeout": 5,
  "timeout-low": 3,
  "timeout-critical": 0,
  "fit-to-screen": true,
  "control-center-width": 400,
  "control-center-height": 800,
  "notification-window-width": 450,
  "keyboard-shortcuts": true,
  "image-visibility": "always",
  "transition-time": 300,
  "hide-on-clear": false,
  "hide-on-action": true,
  "script-fail-notify": true,
  "widgets": [
    "title",
    "mql",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "label": {
      "max-lines": 5,
      "text": "Label Text"
    },
    "mql": {
      "text": "Media Player"
    }
  }
}
