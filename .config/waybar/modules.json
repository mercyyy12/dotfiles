{
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "ΎΕι",
            "2": "ΎΚσ",
            "3": "ΎΒ╗",
            "4": "ΎΕκ",
            "5": "ΎΖς",
            "6": "ΎΓΗ",
            "7": "ΎΓδ",
            "8": "ΎΘΑ",
            "9": "ΎΗα",
            "10": "ΎΕΣ"
        }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/window": {
        "rewrite": {
            "(.*) - Brave": "$1",
            "(.*) - Chromium": "$1",
            "(.*) - Brave Search": "$1",
            "(.*) - Outlook": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "separate-outputs": true,
        "format": "<span color=\"#24273a\" style=\"italic\">{}</span>"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΠΒ",
            "deactivated": "ΎΑμ"
        }
    },
    "tray": {
        "spacing": 5
    },
    "clock": {
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#bb9af7'><b>{}</b></span>",
                "days": "<span color='#7aa2f7'><b>{}</b></span>",
                "weeks": "<span color='#9ece6a'><b>W{}</b></span>",
                "weekdays": "<span color='#e0af68'><b>{}</b></span>",
                "today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        },
        "format": "{:%a %d %b | %I:%M %p}",
        "format-alt": "ΎΕ│  {:%Y-%m-%d ΎΑΩ %H:%M:%S}",
        "interval": 60
    },
    "custom/system": {
        "format": "ΌΣ│",
        "tooltip": false
    },
    "cpu": {
        "interval": 10,
        "format": "ΎΜδ {usage: >3}%",
        "tooltip": false,
        "on-click": "kitty -e btop"
    },
    "memory": {
        "interval": 30,
        "format": "ΎΦ╕ {: >3}%",
        "tooltip": false,
        "on-click": "kitty -e btop"
    },
    "temperature": {
        "interval": 10,
        "thermal-zone": 4,
        "critical-threshold": 80,
        "format": "ΎΜΚ  {temperatureC}┬░C"
    },
    "disk": {
        "interval": 300,
        "format": "ΎΓι {percentage_used}% ",
        "path": "/"
    },
    "group/hardware": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 300,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/system",
            "disk",
            "cpu",
            "memory"
        ]
    },
    "backlight": {
        "format": "{icon} {percent: >3}%",
        "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
        "on-scroll-down": "brightnessctl set 5%-",
        "on-scroll-up": "brightnessctl set +5%"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity: >3}%",
        "format-charging": "ΎΩπ  {capacity}%",
        "format-plugged": "ΎΘο  {capacity}%",
        "format-alt": "{icon}  {time}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "network": {
        "format": "≤░νφ  Disabled",
        "format-wifi": "≤░νρ  {essid}",
        "format-ethernet": "≤░Ν╢  Wired",
        "format-disconnected": "≤░ντ  Disconnected",
        "tooltip-format": "≤░Ν╢ {ifname} via {gwaddri}",
        "tooltip-format-wifi": "≤░νρ  {essid} ({signalStrength}%)\n≤░σθ  {ipaddr}/{cidr}",
        "tooltip-format-ethernet": "≤░Ν╢  {ifname} ({ipaddr}/{cidr})",
        "tooltip-format-disconnected": "≤░ντ  Disconnected",
        "on-click": "~/.config/rofi/scripts/wifi-menu.sh"
    },
    "bluetooth": {
        "format": "<span size='large'>≤░Γψ</span>",
        "format-connected": "<span size='large'>≤░Γ▒</span> {device_alias}",
        "format-connected-battery": "<span size='large'>≤░Γ▒</span> {device_alias} {device_battery_percentage}%",
        "format-disabled": "<span size='large'>≤░Γ▓</span>",
        "format-off": "<span size='large'>≤░Γ▓</span>",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "blueman-manager"
    },
    "pulseaudio": {
        "format": "{icon} {volume: >3}%",
        "format-bluetooth": "≤░Γ▒ {volume: >3}%",
        "format-muted": "≤░ζθ  muted",
        "format-icons": {
            "headphones": "≤░ΜΜ",
            "handsfree": "≤▒ι│",
            "headset": "≤░ΜΟ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "≤░ΕΜ",
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },
    "custom/power": {
        "format": "έΠ╗",
        "on-click": "~/.config/rofi/powermenu/powermenu.sh",
        "tooltip": false
    },
    "custom/launcher": {
        "format": "ΎΑΧ",
        "on-click": "rofi -show drun -replace",
        "tooltip": false
    }
}
